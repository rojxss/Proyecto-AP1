# ─── Supabase ────────────────────────────────────────────────────────────────
# Configuración del proyecto en https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# Service role key: SOLO en servidor, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# ─── Correo — Resend ─────────────────────────────────────────────────────────
# Crear cuenta en https://resend.com (plan free: 100 correos/día, 3000/mes)
# IMPORTANTE: verificar el dominio remitente en el dashboard de Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dirección remitente (debe estar verificada en Resend)
RESEND_FROM_EMAIL=plataforma@escuelasvillasdeayarco.ed.cr

# ─── Chatbot LLM ─────────────────────────────────────────────────────────────
# Proveedor activo: "gemini" | "groq" | "mock"
# Dejar "mock" durante desarrollo si no se tiene API key
LLM_PROVIDER=mock

# Google Gemini (proveedor principal)
# Obtener en https://aistudio.google.com/apikey
# IMPORTANTE: usar Google AI Studio SIN activar facturación para conservar el free tier
# Límites free: 1500 req/día, 1M tokens/min con gemini-2.0-flash
LLM_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_GEMINI_MODEL=gemini-2.0-flash

# Groq (proveedor alternativo — mismo adaptador)
# Obtener en https://console.groq.com/keys
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_GROQ_MODEL=llama-3.1-8b-instant
